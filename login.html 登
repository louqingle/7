<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>许昌科技学校 - 登录</title>
<style>
body{
    margin:0;
    font-family:"Microsoft YaHei";
    background:linear-gradient(135deg,#0057b8,#0084ff);
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}
.login-box{
    width:350px;
    background:white;
    padding:35px;
    border-radius:20px;
    box-shadow:0 10px 30px rgba(0,0,0,.2);
}
h2{
    text-align:center;
    color:#0057b8;
}
input{
    width:100%;
    padding:12px;
    margin:10px 0;
    border:1px solid #ccc;
    border-radius:8px;
}
button{
    width:100%;
    padding:12px;
    background:#0057b8;
    color:white;
    border:none;
    border-radius:8px;
    font-size:16px;
    cursor:pointer;
}
.tip{
    text-align:center;
    color:#666;
    margin-top:15px;
    font-size:14px;
}
</style>
</head>
<body>

<div class="login-box">
    <h2>许昌科技学校</h2>
    <input type="text" id="username" placeholder="学号 / 工号">
    <input type="password" id="password" placeholder="密码">
    <button onclick="login()">登录系统</button>
    <div class="tip">
        演示账号：2026001<br>
        演示密码：123456
    </div>
</div>

<script>
function login(){
    const u=document.getElementById('username').value;
    const p=document.getElementById('password').value;

    if(u==='2026001' && p==='123456'){
        localStorage.setItem('user',u);
        window.location.href='dashboard.html';
    }else{
        alert('账号或密码错误');
    }
}
</script>

</body>
</html>
